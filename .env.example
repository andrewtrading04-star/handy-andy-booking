# ============================================================================
# Handy Andy / Doms — environment variables
# Copy to .env (local) and set the same keys in Vercel → Project → Settings →
# Environment Variables. Never commit real secrets.
# ============================================================================

# --- Supabase ---------------------------------------------------------------
SUPABASE_URL=https://dqlefeafzvjberhjqdps.supabase.co
# ANON key ships inside the PUBLIC widgets. It must NOT be able to read business
# data — the schema's RLS denies it. Used only by the analytics event logger.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImRxbGVmZWFmenZqYmNyaHFoZHBzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODExNzQ1NjQsImV4cCI6MjA5Njc1MDU2NH0.NQhKxuZxQpbj9q_dzg5Fnn6P795Pt27VOkzXB3XFQJ8
# SERVICE ROLE key bypasses RLS. SERVER-SIDE ONLY (admin + technician APIs).
# Get it from Supabase → Project Settings → API → service_role. Never expose it.
SUPABASE_SERVICE_ROLE_KEY=

# --- Admin dashboard / technician app auth ----------------------------------
# Owner password: sees BOTH businesses and can switch between them.
ADMIN_PASSWORD=
# Secretary passwords: scoped to a single business (full control within it).
HANDY_ANDY_PASSWORD=
DOMS_PASSWORD=
# Secret used to sign dashboard/tech session tokens (random long string).
SESSION_SECRET=
# DEV ONLY: set to 1 to let the technician app log in WITHOUT a PIN (pick a tech
# from a dropdown). Leave BLANK/unset in production. Remove before go-live.
TECH_DEV_BYPASS=

# --- Zenbooker (current system of record + import source) -------------------
ZENBOOKER_API_KEY=
# Doms uses a SEPARATE Zenbooker account. Add its key to pull Doms services/
# pricing and to import Doms history (see scripts/import-zenbooker.mjs).
DOMS_ZENBOOKER_API_KEY=

# --- Stripe (card-on-file at booking) ---------------------------------------
STRIPE_SECRET_KEY=

# --- Google Maps (Street View in technician app) ----------------------------
# Get from Google Cloud Console. Enable "Street View Static API" in the project.
# The key is used client-side, so consider restricting to HTTP referrers.
GOOGLE_MAPS_API_KEY=

# --- Email notifications (booking confirmation + feedback emails) ------------
# Resend API: https://resend.com — get key from dashboard.
# Emails are sent from bookings@handyandy.com (can be customized).
RESEND_API_KEY=

# --- SMS notifications (booking, en route, completion) -----------------------
# Twilio: https://www.twilio.com — get Account SID and Auth Token from console.
# Also set TWILIO_PHONE_NUMBER (e.g. +12125551234) to send from.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Public base URL (no trailing slash) used to build SMS review links.
# Locally: http://localhost:3000  |  Production: https://your-domain.com
# If unset, falls back to https://$VERCEL_URL on Vercel.
PUBLIC_URL=
