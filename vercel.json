{
  "buildCommand": "",
  "outputDirectory": "public",
  "crons": [
    { "path": "/api/migrate?action=send_reminders", "schedule": "0 15 * * *" }
  ],
  "rewrites": [
    { "source": "/handy-andy", "destination": "/admin.html" },
    { "source": "/heather", "destination": "/admin.html" },
    { "source": "/doms", "destination": "/admin.html" },
    { "source": "/joey", "destination": "/admin.html" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}
